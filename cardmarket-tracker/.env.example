# === Cardmarket API (OAuth 1.0a) ===
CM_APP_TOKEN=your_app_token_here
CM_APP_SECRET=your_app_secret_here
CM_ACCESS_TOKEN=your_access_token_here
CM_ACCESS_TOKEN_SECRET=your_access_token_secret_here

# === Base de données ===
DATABASE_URL=postgresql://postgres:password@localhost:5432/cardmarket_tracker

# === Configuration collecte ===
COLLECT_HOUR=8          # Heure de la collecte automatique (24h)
COLLECT_MINUTE=0
MAX_RETRIES=3
RETRY_BACKOFF=2         # Secondes (exponentiel)
